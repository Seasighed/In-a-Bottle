      "label": "Everyday Player",
      "description": "Regular engagement without high-intensity play."
    },
    {
      "id": "whale",
      "label": "Whale",
      "description": "High-engagement or high-spend player feedback."
    }
  ],
  "sections": [
    {
      "id": "section_one",
      "title": "Section One",
      "description": "Replace these examples with your own prompts.",
      "icon": "generic",
