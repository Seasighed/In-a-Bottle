          "placeholder": "Participant 001",
          "topic_tags": [
            "identity",
            "profile"
          ],
          "keywords": [
            "name",
            "response label"
          ],
          "emoji": "\u270d\ufe0f"
        },
        {
          "id": "sentiment",
          "prompt": "How would you rate the overall experience?",
          "type": "rating",
          "reward_count": 8,
          "reward_sprite": "res://Assets/UI/Icons/state-complete.svg",
          "min_value": 1,
          "max_value": 5,
          "left_label": "Poor",
          "right_label": "Excellent",
          "rating": {
            "enabled": true,
            "label": "Overall experience"
          },
          "topic_tags": [
            "satisfaction",
            "overall experience"
          ],
          "keywords": [
            "rating",
            "sentiment",
            "quality"
          ],
          "audience_tags": [
            "new_player",
            "everyday_player",
            "whale"
          ],
          "emoji": "\ud83d\udcca"
        },
        {
          "id": "priorities",
          "prompt": "Which areas matter most?",
          "type": "checkbox",
          "choices": [
            "Usability",
            "Clarity",
            "Performance",
            "Accessibility"
          ],
          "topic_tags": [
            "priorities",
            "focus areas"
          ],
          "keywords": [
            "matters most",
            "themes",
            "priority"
          ],
          "emoji": "\u2611\ufe0f"
        },
        {
          "id": "follow_up",
          "prompt": "Anything else we should know?",
          "type": "textarea",
          "placeholder": "Add notes here",
          "topic_tags": [
            "open feedback",
            "final notes"
          ],
          "keywords": [
            "comments",
            "notes",
            "feedback"
          ],
          "emoji": "\ud83d\udcdd"
        }
      ],
      "emoji": "\ud83e\udde9"
    }
  ],
  "guided_presets": [
