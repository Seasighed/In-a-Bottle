  "faq_items": [
    {
      "id": "random_mode_probability",
      "question": "How does Random Mode calculate the odds?",
      "answer": "Random Mode samples uniformly from the eligible question pool. There are {eligible_question_count} eligible questions across {eligible_section_count} section(s) in {whitelist_summary}, so each question currently has {per_question_fraction} = {per_question_probability} chance per spin. {section_probability_breakdown}"
    }
