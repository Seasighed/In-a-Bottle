{
  "id": "starter_survey",
  "title": "Starter Survey",
  "description": "Minimal authoring template for building a new questionnaire.",
  "onboarding_subject": "your game feedback questionnaire",
  "asks_identifying_info": true,
  "audience_profiles": [
    {
      "id": "new_player",
      "label": "New Player",
