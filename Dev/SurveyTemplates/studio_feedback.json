{
  "id": "studio_feedback",
  "title": "Survey Studio",
  "subtitle": "A modular questionnaire shell with section navigation, reusable views, and export-ready data.",
  "onboarding_subject": "the survey shell",
  "asks_identifying_info": true,
  "audience_profiles": [
    {
      "id": "participant",
      "label": "Participant",
      "description": "Answering as someone taking the questionnaire."
    },
    {
      "id": "playtester",
      "label": "Playtester",
      "description": "Answering from hands-on use and friction points."
    },
    {
      "id": "team_member",
      "label": "Team Member",
      "description": "Using the questionnaire to support design, research, or production work."
    },
    {
      "id": "researcher",
      "label": "Researcher",
      "description": "Reviewing the questionnaire for insight quality and reuse."
    }
  ],
  "sections": [
    {
      "id": "participant_profile",
      "title": "Participant Profile",
      "description": "Basic respondent details and segmentation fields.",
      "icon": "profile",
      "header_template": "spotlight",
      "questions": [
        {
          "id": "display_name",
          "prompt": "What name should appear in the response export?",
          "description": "Use a participant code if you want anonymous exports.",
          "type": "short_text",
          "asks_identifying_info": true,
          "required": true,
          "placeholder": "Participant 014",
          "topic_tags": [
            "identity",
            "participant profile"
          ],
          "keywords": [
            "name",
            "participant",
            "export name"
          ],
          "emoji": "\ud83e\udeaa"
        },
        {
          "id": "email",
          "prompt": "What email address should we use for follow-up?",
          "type": "email",
          "asks_identifying_info": true,
          "placeholder": "name@example.com",
          "topic_tags": [
            "follow up",
            "contact"
          ],
          "keywords": [
            "email",
            "follow-up",
            "contact"
          ],
          "emoji": "\u2709\ufe0f"
        },
        {
          "id": "role",
          "prompt": "Which best describes this respondent?",
          "type": "dropdown",
          "required": true,
          "options": [
            "Customer",
            "Playtester",
            "Team member",
            "Research volunteer"
          ],
          "topic_tags": [
            "segmentation",
            "role"
          ],
          "keywords": [
            "player type",
            "role",
            "segment"
          ],
          "audience_tags": [
            "team_member",
            "researcher"
          ],
          "emoji": "\ud83d\udcc2"
        },
        {
          "id": "focus_areas",
          "prompt": "Which themes should this response emphasize?",
          "description": "Choose as many as apply.",
          "type": "multi_choice",
          "options": [
            "Clarity",
            "Usability",
            "Visual design",
            "Performance",
            "Accessibility"
          ],
          "topic_tags": [
            "priorities",
            "focus areas"
          ],
          "keywords": [
            "themes",
            "focus",
            "priority"
          ],
          "emoji": "\u2611\ufe0f"
        },
        {
          "id": "session_date",
          "prompt": "When was this survey completed?",
          "type": "date",
          "placeholder": "2026-03-24",
          "topic_tags": [
            "session",
            "timing"
          ],
          "keywords": [
            "date",
            "completion",
            "timeline"
          ],
          "emoji": "\ud83d\udcc5"
        }
      ],
      "emoji": "\ud83e\uddd1"
    },
    {
      "id": "experience_review",
      "title": "Experience Review",
      "description": "Common survey question families: dropdown, NPS, matrix, ranking, number, and open text.",
      "icon": "review",
      "header_template": "spotlight",
      "questions": [
        {
          "id": "ease_of_use",
          "prompt": "How easy was the survey flow to follow?",
          "description": "Rendered with a chip-based scale template.",
          "type": "scale",
          "required": true,
          "min_value": 1,
          "max_value": 5,
          "left_label": "Hard",
          "right_label": "Easy",
          "view_template": "scale_chips",
          "topic_tags": [
            "usability",
            "navigation"
          ],
          "keywords": [
            "easy",
            "flow",
            "follow"
          ],
          "audience_tags": [
            "participant",
            "playtester"
          ],
          "emoji": "\ud83d\udcca"
        },
        {
          "id": "nps_recommendation",
          "prompt": "How likely are you to recommend this survey shell to a teammate?",
          "description": "Net Promoter Score style question from 0 to 10.",
          "type": "nps",
          "required": true,
          "min_value": 0,
          "max_value": 10,
          "left_label": "Not likely",
          "right_label": "Extremely likely",
          "topic_tags": [
            "recommendation",
            "satisfaction"
          ],
          "keywords": [
            "recommend",
            "nps",
            "team"
          ],
          "emoji": "\ud83d\udcc8"
        },
        {
          "id": "workflow_frequency",
          "prompt": "How often would this questionnaire run in your workflow?",
          "type": "single_choice",
          "options": [
            "One-time intake",
            "Weekly check-in",
            "Monthly review",
            "Event-based follow-up"
          ],
          "topic_tags": [
            "workflow",
            "frequency"
          ],
          "keywords": [
            "how often",
            "cadence",
            "usage"
          ],
          "audience_tags": [
            "team_member",
            "researcher"
          ],
          "emoji": "\ud83d\udd18"
        },
        {
          "id": "weekly_usage",
          "prompt": "About how many responses would this team collect in a typical week?",
          "type": "number",
          "placeholder": "25",
          "topic_tags": [
            "volume",
            "usage"
          ],
          "keywords": [
            "responses",
            "weekly",
            "count"
          ],
          "audience_tags": [
            "team_member",
            "researcher"
          ],
          "emoji": "\ud83d\udd22"
        },
        {
          "id": "topic_ratings",
          "prompt": "Rate each area of the questionnaire.",
