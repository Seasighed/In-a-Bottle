          "type": "matrix",
          "required": true,
          "rows": [
            "Instructions were clear",
            "Navigation felt predictable",
            "The visual hierarchy made sense"
          ],
          "options": [
            "Strongly disagree",
            "Disagree",
            "Neutral",
            "Agree",
            "Strongly agree"
          ],
          "view_template": "matrix",
          "topic_tags": [
